      },
      "item": [
        {
          "id": "bf885639-d520-49e4-8174-a21f5062ad8f",
          "name": "Create a dataset",
          "request": {
            "name": "Create a dataset",
            "description": {
              "content": "Creates a new dataset by uploading data files. Supports multipart form uploads with configurable delimiters for CSV files. The dataset is validated after upload and rows with malformed input can optionally be dropped instead of failing validation.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "datasets"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "<string>",
                  "type": "text",
                  "description": "(Required) The name of the dataset."
                },
                {
                  "key": "type",
                  "value": "<string>",
                  "type": "text",
                  "description": "(Required) The type of dataset. Currently embed-input is the primary type used with the Embed Jobs API. (This can only be one of embed-input,reranker-finetune-input,prompt-completion-finetune-input,single-label-classification-finetune-input,chat-finetune-input)"
                },
                {
                  "key": "data",
                  "type": "file",
                  "description": "(Required) The data file to upload."
                },
                {
                  "key": "delimiter",
                  "value": "<string>",
                  "type": "text",
                  "description": "The delimiter used for CSV file uploads."
                },
                {
                  "key": "dry_run",
                  "value": "<boolean>",
                  "type": "text",
                  "description": "When true, validates the data without creating the dataset."
                },
                {
                  "key": "keep_fields",
                  "value": "<string>",
                  "type": "text",
                  "description": "Comma-separated list of field names to persist in the dataset."
                }
              ]
            }
          },
          "response": [
