  "info": {
    "_postman_id": "eac78560-fede-4d8f-b4f4-a28e5c667244",
    "name": "Cohere Rerank API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Cohere Rerank API takes a query and a list of text documents and returns them ordered by relevance with assigned relevance scores. It is commonly used as a second-stage ranker in retrieval-augmented generation pipelines to improve the quality of search results before passing them to a language model. The API supports multilingual reranking and can significantly improve the precision of search and retrieval systems.\n\nContact Support:\n Name: Cohere Support",
      "type": "text/plain"
    }
  }
