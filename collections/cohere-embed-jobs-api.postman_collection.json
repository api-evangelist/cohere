          "name": "Create an embed job",
          "request": {
            "name": "Create an embed job",
            "description": {
              "content": "Launches an asynchronous embed job for a dataset of type embed-input. The result is a new dataset of type embed-output containing the original text entries and their corresponding embeddings. The input dataset must have a validation status of Validated.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "embed-jobs"
