  "info": {
    "_postman_id": "6e6aac31-9b59-4ac7-8a2c-87a347b8aec6",
    "name": "Cohere Embed Jobs API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Cohere Embed Jobs API allows developers to create and manage batch embedding jobs for processing large volumes of text data asynchronously. Rather than embedding texts one at a time, developers can submit datasets for bulk embedding and monitor job progress. This is useful for initializing vector databases, processing large document collections, and other scenarios where embedding large amounts of content is needed.\n\nContact Support:\n Name: Cohere Support",
      "type": "text/plain"
    }
  }
