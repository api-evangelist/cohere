    "_postman_id": "09172c37-1f52-46be-9424-624007bcc701",
    "name": "Cohere Detokenize API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Cohere Detokenize API converts a sequence of token IDs back into their corresponding text string using the tokenizer for a specified model. It is the inverse operation of the Tokenize API and is useful for inspecting model outputs at the token level, debugging tokenization behavior, and reconstructing text from token representations.\n\nContact Support:\n Name: Cohere Support",
      "type": "text/plain"
    }
