{
  "opencollection": "1.0.0",
  "info": {
    "name": "Cohere Embed Jobs API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Embed Jobs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List embed jobs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.cohere.com/v1/embed-jobs"
          },
          "docs": "Returns a list of all embed jobs history for the authenticated user. Includes job status, model, and dataset information for each job."
        },
        {
          "info": {
            "name": "Create an embed job",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.cohere.com/v1/embed-jobs",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Launches an asynchronous embed job for a dataset of type embed-input. The result is a new dataset of type embed-output containing the original text entries and their corresponding embeddings. The input dataset must have a validation status of Validated."
        },
        {
          "info": {
            "name": "Fetch an embed job",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.cohere.com/v1/embed-jobs/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "The unique identifier of the embed job."
              }
            ]
          },
          "docs": "Retrieves the details and status of a specific embed job by its identifier."
        },
        {
          "info": {
            "name": "Cancel an embed job",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.cohere.com/v1/embed-jobs/:id/cancel",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "The unique identifier of the embed job."
              }
            ]
          },
          "docs": "Cancels an active embed job. Only jobs that are currently processing can be cancelled."
        }
      ]
    }
  ],
  "bundled": true
}