        {
          "id": "c5560b90-d733-42dd-999d-b8cd7404af8d",
          "name": "List available models",
          "request": {
            "name": "List available models",
            "description": {
              "content": "Returns a paginated list of models available for use. Supports filtering by compatible endpoint and default models. Includes details such as model name, supported endpoints, context length, and default status.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "models"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "page_size",
                  "value": "20",
                  "description": "Maximum number of models to include in a page. Defaults to 20."
                },
                {
                  "disabled": false,
                  "key": "page_token",
                  "value": "<string>",
                  "description": "Page token provided in the next_page_token field of a previous response for pagination."
                },
                {
                  "disabled": false,
                  "key": "endpoint",
                  "value": "<string>",
                  "description": "When provided, filters the list of models to only those compatible with the specified endpoint."
                },
                {
                  "disabled": false,
                  "key": "default_only",
                  "value": "<boolean>",
                  "description": "When true, filters the list of models to only the default model for the specified endpoint."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
