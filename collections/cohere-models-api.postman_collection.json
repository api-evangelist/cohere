  "info": {
    "_postman_id": "05555a13-6119-4eda-a8ba-3110ea4b0d07",
    "name": "Cohere Models API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Cohere Models API allows developers to list and retrieve information about available Cohere models, including the Command, Embed, and Rerank model families. It provides details such as model names, versions, supported endpoints, context lengths, and capabilities. This API is useful for programmatically discovering which models are available and selecting the appropriate model for a given task.\n\nContact Support:\n Name: Cohere Support",
      "type": "text/plain"
    }
  }
